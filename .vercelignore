# Vercel ignore file

# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Development files
.next/dev
.env.local
.env.development.local
.env.test.local
.env.production.local

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Temporary files
*.tmp
*.temp
.temp/

# Logs
logs/
*.log

# Coverage directory used by tools like istanbul
coverage/

# Git
.git/

# Documentation drafts
docs/drafts/
*.draft.md

# Test files (optional - remove if you want to run tests on Vercel)
__tests__/
*.test.*
*.spec.*